# Registration and admin controls
REGISTRATION_REQUIRES_INVITE=true
REQUIRE_ADMIN_APPROVAL=true
# Use either ADMIN_EMAILS (comma-separated) or ADMIN_EMAIL (single email).
# ADMIN_EMAILS=dmunoz2460@gmail.com
ADMIN_EMAIL=dmunoz2460@gmail.com

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
