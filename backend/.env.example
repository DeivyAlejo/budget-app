APP_NAME=Budget App API
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-in-dev
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DATABASE_URL=sqlite:///./budget_app.db

# URL used by OAuth redirect flows.
FRONTEND_URL=http://localhost:5173

# Comma-separated list of allowed frontend origins for browser requests.
# Add your LAN URL when accessing from another machine.
# Example:
# CORS_ORIGINS=http://localhost:5173,http://192.168.150.15:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
